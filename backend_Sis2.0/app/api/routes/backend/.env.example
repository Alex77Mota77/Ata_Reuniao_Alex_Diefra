# ── Ambiente ──────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB Atlas ─────────────────────────────────────────────
# Cole aqui a sua connection string do Atlas
MONGODB_URL=mongodb+srv://<usuario>:<senha>@<cluster>.mongodb.net/<banco>?retryWrites=true&w=majority
DATABASE_NAME=bd_diefra_ata_reuniao

# ── JWT ───────────────────────────────────────────────────────
SECRET_KEY=sua-chave-secreta-aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── CORS — adicione os domínios do seu frontend ──────────────
CORS_ORIGINS=["http://localhost:4200","https://seu-site.netlify.app"]

# ── Log ───────────────────────────────────────────────────────
LOG_LEVEL=debug
